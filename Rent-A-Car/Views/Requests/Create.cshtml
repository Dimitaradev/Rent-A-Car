@using Microsoft.AspNetCore.Identity;
@using Rent_A_Car.Controllers;
@model Rent_A_Car.Models.Requests
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Requests</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="CarID" class="control-label"></label>
                <select asp-for="CarID" class ="form-control" asp-items="ViewBag.CarID"></select>
            </div>
            <div class="form-group">
                <label asp-for="UserID" class="control-label"></label>
                <input asp-for="UserID" class ="form-control" value="@ViewBag.UserID"/>
            </div>
            <div class="form-group">
                <label asp-for="RequestStart" class="control-label"></label>
                <input asp-for="RequestStart" class="form-control" />
                <span asp-validation-for="RequestStart" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RequestEnd" class="control-label"></label>
                <input asp-for="RequestEnd" class="form-control" />
                <span asp-validation-for="RequestEnd" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
